# =============================================================
# Python bytecode & build artifacts
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/

# =============================================================
# Virtual environments
# =============================================================
env/
venv/
.venv/
.env/

# =============================================================
# Environment & secrets — NEVER commit credentials
# =============================================================
.env
.env.*
*.env
secrets.json
service_account*.json
*credentials*.json
gee_credentials.json
application_default_credentials.json
token.json

# =============================================================
# Large binary data — exceeds GitHub 100 MB limit
# =============================================================
data/raw/*.tif
data/raw/*.nc
data/processed/delhi_thermal_features.csv

# =============================================================
# Trained model weights — large binary blobs
# Store on DVC / HuggingFace Hub / GCS instead
# =============================================================
models/*.pth
models/*.pt
models/*.onnx
models/*.pkl
models/*.joblib

# =============================================================
# OSMnx / requests cache
# =============================================================
cache/

# =============================================================
# Jupyter notebook checkpoints & scratch
# =============================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================
# Streamlit secrets
# =============================================================
.streamlit/secrets.toml

# =============================================================
# OS generated files
# =============================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================
# IDE configs
# =============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================
# Coverage & testing artifacts
# =============================================================
.coverage
htmlcov/
.pytest_cache/

# =============================================================
